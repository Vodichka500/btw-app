// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

generator zod {
  provider              = "zod-prisma-types"
  output                = "../src/zod"
  prismaClientPath      = "@btw-app/db/client"
  useMultipleFiles      = true // Разбивает гигантский файл на аккуратные папки
  createInputTypes      = false // Убивает серверные фильтры
  addIncludeQueries     = false // Убивает кривые ArgsSchema (ошибка сборщика)
  addSelectQueries      = false // Убивает кривые SelectSchema
  prismaJsonNullability = false // Убивает импорты { Prisma } из @prisma/client
}

// ==========================================
// 🛡️ БЛОК BETTER AUTH
// ==========================================

enum Role {
  ADMIN
  MANAGER
  TEACHER
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  role      Role    @default(TEACHER)
  alfaEmail String? @unique @map("alfa_email")
  alfaToken String? @map("alfa_token")
  tgChatId  String? @unique @map("tg_chat_id")

  teacherId Int?     @map("teacher_id")
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ==========================================
// 📂 ДОМЕННЫЕ ТАБЛИЦЫ (Твоя бизнес-логика)
// ==========================================

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  order     Int       @default(0)
  parentId  Int?
  createdAt DateTime  @default(now())
  deletedAt DateTime? // Soft delete

  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  snippets Snippet[]

  @@map("categories")
}

model Snippet {
  id         Int       @id @default(autoincrement())
  title      String
  body       String
  variables  Json      @default("[]")
  categoryId Int
  favorite   Boolean   @default(false)
  color      String?   @default("#FFFFFF")
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime? // Soft delete

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("snippets")
}

model AlfaSettings {
  id             Int       @id @default(autoincrement()) // В Prisma ID обязателен
  email          String
  apiKey         String
  token          String?
  tokenExpiresAt DateTime?

  @@map("alfa_settings")
}

model Subject {
  id        Int    @id @default(autoincrement())
  alfacrmId Int?
  name      String
  order     Int    @default(0)

  teachers TeacherSubject[]

  @@map("subjects")
}

model Teacher {
  id        Int     @id @default(autoincrement())
  alfacrmId Int
  name      String
  email     String?
  phone     String?
  avatarUrl String?
  note      String? @default("Заметка")

  subjects     TeacherSubject[]
  workingHours TeacherWorkingHour[]
  users        User[]

  @@map("teachers")
}

// Связь Многие-ко-многим (Учителя <-> Предметы)
model TeacherSubject {
  teacherId Int
  subjectId Int

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([teacherId, subjectId]) // Композитный первичный ключ
  @@map("teacher_subjects")
}

model TeacherWorkingHour {
  id        Int    @id @default(autoincrement())
  teacherId Int
  dayIndex  Int // 0(Пн) - 6(Вс)
  timeFrom  String // Формат "HH:MM"
  timeTo    String // Формат "HH:MM"

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_working_hours")
}

model Customer {
  id         Int     @id @default(autoincrement())
  alfaId     Int     @unique @map("alfa_id")
  isSelfPaid Boolean @default(true) @map("is_self_paid")
  name       String

  teacherIds Int[]   @map("teacher_ids")
  isStudy    Int     @default(1) @map("is_study")
  isRemoved  Boolean @default(false) @map("is_removed")
  note       String? @map("note")

  // Telegram ID чатов
  studentTgChatId String? @map("student_tg_chat_id")
  parentTgChatId  String? @map("parent_tg_chat_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messageLogs MessageLog[]

  @@map("customers")
}

enum MessageStatus {
  SUCCESS
  FAILED
}

model MessageLog {
  id       Int      @id @default(autoincrement())
  alfaId   Int      @map("alfa_id")
  customer Customer @relation(fields: [alfaId], references: [alfaId])

  messageBody String        @map("message_body")
  status      MessageStatus
  errorReason String?       @map("error_reason") // Описание ошибки, если FAILED

  createdAt DateTime @default(now()) @map("created_at")

  @@index([alfaId])
  @@map("message_logs")
}

model BillingTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("billing_templates")
}

model BillingLog {
  id               Int           @id @default(autoincrement())
  alfaId           Int           @map("alfa_id")
  month            Int
  year             Int
  amountCalculated Float         @map("amount_calculated")
  messageBody      String        @map("message_body") @db.Text
  sentAt           DateTime      @default(now()) @map("sent_at")
  status           MessageStatus

  @@map("billing_logs")
}
model SyncState {
  type     String   @id
  syncedAt DateTime @default(now()) @updatedAt @map("synced_at")

  @@map("sync_states")
}

model AlfaSubject {
  id     Int    @id @default(autoincrement())
  alfaId Int    @unique @map("alfa_id")
  name   String

  @@map("alfaSubjects")
}

model TelegramSession {
  id            Int      @id @default(1)
  phoneNumber   String?
  sessionString String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("telegram_sessions")
}
