{
  "name": "@btw-app/server",
  "version": "2.2.1",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:db:push": "dotenv -e .env.test -- pnpm --filter @btw-app/db exec prisma db push --accept-data-loss",
    "test": "dotenv -e .env.test -- tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "test:temp-router": "dotenv -e .env.test -- tsx --test tests/customer.test.ts",
    "test:coverage": "dotenv -e .env.test -- c8 --reporter=text --reporter=html tsx --test --test-concurrency=1 tests/**/*.test.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@btw-app/db": "workspace:*",
    "@btw-app/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@trpc/server": "10.45.2",
    "better-auth": "catalog:",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "input": "^1.0.1",
    "superjson": "^2.2.6",
    "telegram": "^2.26.22",
    "trpc-panel": "^1.3.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
