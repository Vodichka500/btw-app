{
  "version": "1.1.0",
  "name": "btw-app-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:electron": "npm run dev --workspace=@btw-app/electron",
    "build:electron": "npm run build --workspace=@btw-app/electron",
    "seed:electron": "npm run seed --workspace=@btw-app/electron",
    "dev:server": "npm run dev --workspace=@btw-app/server",
    "build:server": "npm run build --workspace=@btw-app/server",
    "start:server": "npm run start --workspace=@btw-app/server",
    "db:generate": "npm run db:generate --workspace=@btw-app/server",
    "db:migrate": "npm run db:migrate --workspace=@btw-app/server",
    "db:studio": "npm run db:studio --workspace=@btw-app/server"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@trpc/server": "^10.45.2",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "0.7.1",
    "fastify": "^4.28.1",
    "zod": "3.23.8"
  },
  "overrides": {
    "zod": "3.23.8",
    "drizzle-zod": {
      "zod": "3.23.8"
    }
  }
}
