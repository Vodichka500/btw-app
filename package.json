{
  "name": "temp-turbo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --ui=stream",
    "dev:server": "turbo run dev --filter=@btw-app/server --ui=stream",
    "dev:electron": "turbo run dev --filter=@btw-app/electron --ui=stream",
    "build:electron": "turbo run build --filter=@btw-app/electron",
    "seed:electron": "pnpm --filter @btw-app/electron seed",
    "db:generate": "pnpm --filter @btw-app/db generate",
    "db:migrate": "pnpm --filter @btw-app/db migrate",
    "release": "pnpm run build:electron && pnpm --filter @btw-app/electron run release:app"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "zod": "^3.24.0",
      "@trpc/server": "10.45.2",
      "@trpc/client": "10.45.2",
      "@trpc/react-query": "10.45.2",
      "zod-to-json-schema": "3.24.1"
    },
    "onlyBuiltDependencies": [
      "electron",
      "prisma",
      "@prisma/engines",
      "esbuild",
      "sharp",
      "electron-winstaller"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
